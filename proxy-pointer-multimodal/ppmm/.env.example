# --- Required ---------------------------------------------------------------
# Your OpenAI API key
OPENAI_API_KEY="sk-..."
# Or Azure OpenAI keys
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=...

# --- Optional overrides (sensible defaults shown) ---------------------------
# PP_GEN_MODEL=gpt-4o                   # generation + vision model
# PP_EMBED_MODEL=text-embedding-3-large  # embedding model
# PP_EMBED_DIM=3072                      # embedding dimensionality (3072 for large)
# PP_RECALL_K=200                         # broad vector recall
# PP_CANDIDATE_K=50                       # unique candidates re-ranked
# PP_FINALIST_K=5                         # sections loaded for synthesis
# PP_DATA_DIR=./data                      # where everything is stored








